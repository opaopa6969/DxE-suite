[8.4, "o", "\u001b[1;35m│\u001b[0m   \u001b[1mClaude Code\u001b[0m v1.0.20                                              \u001b[1;35m│\u001b[0m\r\n"]
[8.5, "o", "\u001b[1;35m│\u001b[0m   \u001b[2m~/my-project\u001b[0m                                                     \u001b[1;35m│\u001b[0m\r\n"]
