{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "outDir": "./dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "declaration": true,
    "skipLibCheck": true
  },
  "include": ["parser/**/*.ts", "graph/**/*.ts", "context/**/*.ts", "cli/**/*.ts", "server/**/*.ts", "config.ts"],
  "exclude": ["node_modules", "dist", "test"]
}
